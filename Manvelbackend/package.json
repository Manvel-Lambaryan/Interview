{
  "name": "url-shortener-backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch src/main.js",
    "start": "node src/main.js",
    "db:generate": "node scripts/prisma-env.mjs generate",
    "db:migrate": "node scripts/prisma-env.mjs migrate dev",
    "db:migrate:deploy": "node scripts/prisma-env.mjs migrate deploy",
    "db:push": "node scripts/prisma-env.mjs db push",
    "test": "node --test",
    "lint": "echo \"Define eslint in package.json\" && exit 0"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "prisma": "^6.6.0"
  }
}
