generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String     @id @default(uuid())
  name       String
  email      String     @unique
  created_at DateTime   @default(now())
  short_urls ShortURL[]

  @@map("users")
}

/// Shortened link owned by a User. Deleting the user removes their short URLs (ON DELETE CASCADE).
model ShortURL {
  id            String    @id @default(uuid())
  user_id       String
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  original_url  String
  short_code    String    @unique
  created_at    DateTime  @default(now())
  expires_at    DateTime?

  @@map("short_urls")
}

/// Tag label; unique name so one canonical tag per label in the system.
model Tag {
  id   String @id @default(uuid())
  name String @unique

  @@map("tags")
}
